# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"

# Supabase server environment (backend only)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Frontend runtime (Vercel)
VITE_SOCKET_URL="https://your-backend-host.example.com"
VITE_API_BASE_URL="https://your-backend-host.example.com"

# Comma-separated allowed frontend origins for Socket.io CORS
CORS_ORIGIN="https://your-vercel-app.vercel.app"
